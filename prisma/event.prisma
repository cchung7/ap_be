model Event {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  category           EventCategory @default(VOLUNTEERING)
  date               DateTime
  startTime          String
  endTime            String
  location           String
  description        String?
  capacity           Int           @default(0)
  totalRegistered    Int           @default(0)

  pointsValue        Int           @default(0)

  checkInCodeHash    String?
  checkInCodeExpires DateTime?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  attendances        EventAttendance[]

  @@index([date])
  @@index([date, startTime])
  @@index([category, date])
  @@map("events")
}
